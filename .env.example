# Core Keeper Dedicated Server Configuration
# Copy this file to .env and adjust as needed
#
#
# This file documents ALL supported environment variables.
# The container image (escaping/core-keeper-dedicated) uses
# these variables to configure the Core Keeper server.
# ============================================================

# ============ Server Settings ============
# ----------------------------------------
# Basic server identification and capacity

# Server name displayed in the server browser and join dialog
# Default: "Core Keeper Server"
WORLD_NAME=Core Keeper Server

# Maximum number of players allowed to connect
# Valid range: 1-8 (Core Keeper max players)
MAX_PLAYERS=8


# ============ World Configuration ============
# ------------------------------------------
# Controls world generation and behavior

# World name/identifier for the server
# Default: Same as WORLD_NAME
# Note: This is separate from WORLD_NAME for display purposes
WORLD_NAME_INTERN=

# Which world slot to use (0-9)
# Default: 0
# Valid range: 0-9
# Note: Each slot holds a different world save
WORLD_INDEX=0

# Seed number for world generation
# Default: "" (empty = random seed)
# Valid range: Any integer
# Note: If empty, a random seed will be generated.
#       Added in v1.1. Use either WORLD_SEED or HASHED_WORLD_SEED, not both
# Hint: Share this seed with friends to play on the same world
WORLD_SEED=

# Hashed seed for world generation (alternative to WORLD_SEED)
# Default: "" (empty = random)
# Valid: Any string (will be hashed)
# Note: Added in v1.1. Use either WORLD_SEED or HASHED_WORLD_SEED, not both
HASHED_WORLD_SEED=

# World difficulty/mode
# Default: 0
# Valid values:
#   0 = Normal
#   1 = Hard
#   2 = Creative
#   4 = Casual
WORLD_MODE=0

# Season override
# Default: Not set (uses real-world date/season)
# Valid values:
#   0 = None (no season)
#   1 = Easter
#   2 = Halloween
#   3 = Christmas
#   4 = Valentine
#   5 = Anniversary
#   6 = CherryBlossom
#   7 = LunarNewYear
# Note: Leave empty to use actual calendar season
SEASON=


# ============ Network Settings ============
# ------------------------------------------
# Controls connectivity and how players connect

# Leave empty to use SDR (Steam Datagram Relay) - RECOMMENDED!
# SDR uses Valve's relay servers, hides your IP, no port forwarding needed.
# Players can join via "Friends" > "Join Game" without knowing your IP.
#
# Set to a port number (e.g., 27015) for Direct Connection mode.
# Direct Connect requires:
#   - Port forwarding on your router
#   - Opening the port in your firewall
#   - Players know your public IP address
# Default: "" (empty = SDR mode) - RECOMMENDED!
# Valid range: 1024-65535
SERVER_PORT=

# IP address for the server to bind to
# Default: 0.0.0.0 (binds to all interfaces)
# Only needed if you have multiple network interfaces and want to restrict
# Valid: IPv4 or IPv6 address
# Note: Usually not needed; leave empty for default
SERVER_IP=

# Server password for direct connections
# Default: "" (empty = no password required)
# Maximum length: 28 characters
# Note: Only applies to Direct Connection mode (when SERVER_PORT is set)
# If empty in SDR mode, no password is required
PASSWORD=

# Restrict players to specific platform
# Default: "" (empty = allow all platforms)
# Valid values:
#   1 = Steam only
#   2 = Epic Games only
#   3 = Microsoft only
#   4 = GOG only
# Note: Only works with Direct Connection mode (SERVER_PORT must be set)
ALLOW_ONLY_PLATFORM=


# ============ Game Server Identity ============
# ------------------------------------------
# Custom Game ID for the server

# Custom GameID for direct server listing
# Default: "" (empty = auto-generated)
# Requirements:
#   - Must be 15-28 characters long
#   - Must be alphanumeric (letters and numbers only)
#   - Must be unique (no other server using same ID)
# Note: Only applies to Direct Connection mode
# Warning: An invalid or duplicate GameID will prevent server from starting
GAME_ID=


# ============ Legacy Content (v1.1+) ============
# ------------------------------------------
# Enable biome/content that was available in older versions

# Activate specific legacy biomes for worlds created before v1.1
# Default: "" (empty = no legacy content)
# Valid values (comma-separated):
#   GiantCicadaBossDungeon
#   NatureBiomeCicadas
#   GuaranteedOases
#   BiomeStatues
#   AbioticFactor
# Note: Once enabled, cannot be disabled for that world
# Warning: Only for worlds created before v1.1
# Example: GiantCicadaBossDungeon,NatureBiciadas
ACTIVATE_CONTENT=

# Activate ALL legacy content biomes
# Default: false
# Valid values: true, false
# Note: Same as setting ACTIVATE_CONTENT to all values
# Warning: Only for worlds created before v1.1
ACTIVATE_ALL_CONTENT=false


# ============ Mod Support ============
# ------------------------------------------
# Enable and configure mods from mod.io
#
# HOW TO USE MODS:
# 1. Get your API key from https://mod.io/me/access
# 2. Note your API URL (shown alongside the key, e.g., https://u-12345.modapi.io/v1)
# 3. Set MODS_ENABLED=true
# 4. Set MODIO_API_KEY=your_api_key
# 5. Set MODIO_API_URL=your_api_url
# 6. List mods in MODS= (see below)
#
# IMPORTANT:
# - Server-restricted mods only (not client-only mods)
# - Mod dependencies are NOT auto-installed - add them manually
# - Mods reinstall on every container restart (updates automatically)

# Enable mod support
# Default: false
# Valid values: true, false
# Note: Must be true for any mod functionality
MODS_ENABLED=false

# mod.io API key
# Default: "" (empty)
# How to get:
#   1. Go to https://mod.io/me/access
#   2. Click "Create a new API key"
#   3. Give it a name (e.g., "Core Keeper Server")
#   4. Copy the key (long alphanumeric string)
#   5. Copy the API URL shown with the key (e.g., https://u-12345.modapi.io/v1)
# Note: Both API key AND API URL are REQUIRED for mods to work
# Warning: Keep this secret! Don't share publicly
MODIO_API_KEY=

# mod.io API URL
# Default: "" (empty)
# How to get: See MODIO_API_KEY instructions above
# This is your personal mod.io API endpoint
# Format: https://u-XXXXX.modapi.io/v1
# Note: REQUIRED when using mods - both key and URL are needed
# Example: https://u-12345.modapi.io/v1
MODIO_API_URL=

# List of mods to install
# Default: "" (empty = no mods)
# Format: <mod_id>[:<version>],<mod_id>[:<version>],...
#
# How to find mod IDs:
#   - Look at the mod.io URL: https://mod.io/g/corekeeper/m/core-lib
#   - The ID is the last part: "core-lib"
#
# Version (optional):
#   - Omit version to install latest
#   - Specify version to pin to that release
#
# Examples:
#   MODS=core-lib                           # Latest CoreLib
#   MODS=core-lib,coreliblocalization      # Multiple mods, latest versions
#   MODS=core-lib:3.2.1                    # Specific version
#   MODS=core-lib:3.2.1,ck-qol:1.9.4       # Multiple with specific versions
#
# Finding mods:
#   Browse: https://mod.io/g/corekeeper
#
# Warning: Don't install client-only mods - they won't work on server!
# Note: Mods are reinstalled on every start (auto-updates to latest if no version)
# Example: core-lib,coreliblocalization,ck-qol
MODS=


# ============ Discord Integration ============
# ------------------------------------------
# Discord webhook notifications for server events
#
# HOW TO SET UP:
# 1. Create a Discord server (or use existing)
# 2. Go to Server Settings > Integrations > Webhooks
# 3. Create a new webhook, choose channel
# 4. Copy the webhook URL
# 5. Paste into DISCORD_WEBHOOK_URL below
#
# Message variables (use in custom messages):
#   ${char_name}   - Player's character name
#   ${steamid}     - Player's Steam ID
#   ${world_name} - Server's world name
#   ${gameid}      - Server's Game ID
#   ${reason}      - Disconnect reason (for leave messages)
#   ${public_ip}   - Server's public IP (direct connect)
#   ${port}        - Server port (direct connect)
#   ${password}    - Server password (direct connect)
#   ${join_string} - Full join command (direct connect)

# Discord webhook URL
# Default: "" (empty = no Discord notifications)
# How to get:
#   1. Server Settings > Integrations > Webhooks
#   2. Create Webhook > Choose channel
#   3. Copy webhook URL
# Note: Leave empty to disable all Discord notifications
# Example: https://discord.com/api/webhooks/123456789/abcdefghijklmnopqrstuvwxyz
DISCORD_WEBHOOK_URL=

# -------- Player Join Notifications --------

# Enable/disable player join messages
# Default: true
# Valid values: true, false
# Example: true
DISCORD_PLAYER_JOIN_ENABLED=true

# Custom message for player join
# Default: "${char_name} (${steamid}) has joined the server."
# Variables: ${char_name}, ${steamid}
# Example: "${char_name} joined the game!"
DISCORD_PLAYER_JOIN_MESSAGE="${char_name} (${steamid}) has joined the server."

# Embed title for join messages
# Default: "Player Joined"
# Example: New Explorer
DISCORD_PLAYER_JOIN_TITLE=Player Joined

# Embed color for join messages (decimal color code)
# Default: 47456 (green-ish)
# Color picker: https://discordcolor.com
# Example: 3066993 (green)
DISCORD_PLAYER_JOIN_COLOR=47456

# -------- Player Leave Notifications --------

# Enable/disable player leave messages
# Default: true
# Valid values: true, false
# Example: true
DISCORD_PLAYER_LEAVE_ENABLED=true

# Custom message for player leave
# Default: "${char_name} (${steamid}) has disconnected. Reason: ${reason}."
# Variables: ${char_name}, ${steamid}, ${reason}
# Example: "${char_name} left the server."
DISCORD_PLAYER_LEAVE_MESSAGE="${char_name} (${steamid}) has disconnected. Reason: ${reason}."

# Embed title for leave messages
# Default: "Player Left"
# Example: Goodbye
DISCORD_PLAYER_LEAVE_TITLE=Player Left

# Embed color for leave messages (decimal color code)
# Default: 11477760 (red-ish)
# Example: 15158332 (red)
DISCORD_PLAYER_LEAVE_COLOR=11477760

# -------- Server Start Notifications --------

# Enable/disable server start messages
# Default: true
# Valid values: true, false
# Example: true
DISCORD_SERVER_START_ENABLED=true

# Custom message for server start
# Default: "**World:** ${world_name}\n**GameID:** ${gameid}"
# Variables: ${world_name}, ${gameid}, ${allowed_platforms}, ${public_ip}, ${port}, ${password}, ${join_string}
# Note: ${allowed_platforms}, ${public_ip}, ${port}, ${password}, ${join_string} only available in Direct Connect mode
# Example: "Server is now online! World: ${world_name}"
DISCORD_SERVER_START_MESSAGE="**World:** ${world_name}\n**GameID:** ${gameid}"

# Embed title for server start messages
# Default: "Server Started"
# Example: Server Online
DISCORD_SERVER_START_TITLE=Server Started

# Embed color for start messages (decimal color code)
# Default: 2013440 (blue-ish)
# Example: 2123412 (blue)
DISCORD_SERVER_START_COLOR=2013440

# -------- Server Stop Notifications --------

# Enable/disable server stop messages
# Default: true
# Valid values: true, false
# Example: true
DISCORD_SERVER_STOP_ENABLED=true

# Custom message for server stop
# Default: "" (empty = no message)
# Variables: ${world_name}, ${gameid}
# Note: Leave empty to show no embed on stop
# Example: "Server shutting down..."
DISCORD_SERVER_STOP_MESSAGE=

# Embed title for server stop messages
# Default: "Server Stopped"
# Example: Server Offline
DISCORD_SERVER_STOP_TITLE=Server Stopped

# Embed color for stop messages (decimal color code)
# Default: 12779520 (yellow-ish)
# Example: 10038562 (red)
DISCORD_SERVER_STOP_COLOR=12779520


# ============ Container Settings ============
# ------------------------------------------
# Docker container configuration

# Process User ID - file ownership for created files
# Default: 1000
# Note: Set to your host user's UID for proper file permissions
# Run 'id' in terminal to find your UID
# Example: 1000
PUID=1000

# Process Group ID - file ownership for created files
# Default: 1000
# Note: Set to your host user's GID for proper file permissions
# Run 'id' in terminal to find your GID
# Example: 1000
PGID=1000

# ARM64 device type (for Raspberry Pi, Mac M-series, etc.)
# Default: generic
# Valid values:
#   generic     - Generic ARM64 (default, works most cases)
#   rpi3        - Raspberry Pi 3
#   rpi4-pre3   - Raspberry Pi 4
#   rpi5        - Raspberry Pi 5 (4K page size)
#   rpi5_16k    - Raspberry Pi 5 (16K page size)
#   m1          - Apple M1/M2/M3 (Mac with Apple Silicon)
#   adlink      - ADLink Ampere Altra (Oracle ARM CPUs)
# Note: Only needed for ARM devices; x86_64 ignores this
# Example: generic
ARM64_DEVICE=generic


# ============ Advanced Options ============
# ------------------------------------------
# Rarely needed configuration

# Use Depot Downloader instead of steamcmd
# Default: false
# Valid values: true, false
# Note: For systems incompatible with 32-bit binaries
# Warning: Usually not needed; leave as default
# Example: false
USE_DEPOT_DOWNLOADER=false
